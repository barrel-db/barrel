%%% Barrel umbrella build.
%%%
%%% This is a rebar3 umbrella project. Each application under apps/ keeps its
%%% own rebar.config (erl_opts, NIF build hooks, xref, dialyzer, profiles); the
%%% external dependencies they declare are aggregated here at build time, so
%%% there is no top-level {deps, ...} block.
%%%
%%% Default build: barrel_docdb, barrel_vectordb, barrel_embed, barrel_rerank.
%%% barrel_faiss is excluded by default because it needs the FAISS C++ library;
%%% opt it in with `rebar3 as faiss compile`.

%% Restrict the default app set so a plain `rebar3 compile` never requires the
%% FAISS C++ toolchain. The `faiss` profile below adds barrel_faiss back.
{project_app_dirs, [
    "apps/barrel_crypto",
    "apps/barrel_docdb",
    "apps/barrel_vectordb",
    "apps/barrel_embed",
    "apps/barrel_rerank",
    "apps/barrel",
    "apps/barrel_spaces"
]}.

%% Some dependencies (instrument and its hackney dep) still use the prefix
%% `catch' operator, deprecated on OTP 29. Scope the suppression to them so the
%% umbrella's own code stays strict.
{overrides, [
    {add, instrument, [{erl_opts, [nowarn_deprecated_catch]}]},
    {add, hackney, [{erl_opts, [nowarn_deprecated_catch]}]}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% Development shell starts the two primary databases.
{shell, [
    {apps, [barrel_docdb, barrel_vectordb]}
]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.
{ct_opts, [{verbose, true}]}.

%% Umbrella-level xref: same checks as every app (no exports_not_used:
%% the whole umbrella is a library surface). Without this, rebar3 falls
%% back to its built-in default at the root, which flags every export.
%% CI runs per-leaf xref with each app's own config and ignores.
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.
{xref_ignores, [
    %% yecc emits return_error/2 for grammar action code to call
    {barrel_bql_parser, return_error, 2}
]}.

{profiles, [
    {test, [
        {deps, [{meck, "1.2.0"}]}
    ]},
    %% Opt the FAISS app into the build. Requires the FAISS C++ library.
    %%   rebar3 as faiss compile
    {faiss, [
        {project_app_dirs, [
            "apps/barrel_crypto",
            "apps/barrel_docdb",
            "apps/barrel_vectordb",
            "apps/barrel_embed",
            "apps/barrel_rerank",
            "apps/barrel",
            "apps/barrel_spaces",
            "apps/barrel_faiss"
        ]}
    ]},
    %% Opt the network server into the build. Pulls livery and its transports;
    %% kept out of the default (embeddable) build.
    %%   rebar3 as server compile | rebar3 as server shell
    {server, [
        {project_app_dirs, [
            "apps/barrel_crypto",
            "apps/barrel_docdb",
            "apps/barrel_vectordb",
            "apps/barrel_embed",
            "apps/barrel_rerank",
            "apps/barrel",
            "apps/barrel_spaces",
            "apps/barrel_server"
        ]},
        {shell, [
            {apps, [barrel_server]}
        ]},
        {relx, [
            {release, {barrel_server, "0.1.0"}, [
                barrel_server,
                sasl,
                runtime_tools,
                instrument
            ]},
            {dev_mode, true},
            {include_erts, false},
            {extended_start_script, true}
        ]}
    ]},
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.

%% Umbrella release skeleton. The primary deliverables are `rebar3 compile` and
%% the test suites; release assembly can be refined in a later change.
{relx, [
    {release, {barrel, "0.1.0"}, [
        barrel_crypto,
        barrel_docdb,
        barrel_vectordb,
        barrel_embed,
        barrel_rerank,
        barrel,
        barrel_spaces,
        sasl,
        runtime_tools,
        instrument
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "rel/sys.config"},
    {vm_args, "rel/vm.args"}
]}.
