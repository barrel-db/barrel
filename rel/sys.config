%%% Minimal configuration for the umbrella `barrel` release.
%%% Per-application defaults come from each app's .app.src env; override here as
%%% needed for a deployment. Per-app standalone configs stay under each app's
%%% own config/ directory.
[
    {barrel_docdb, [
        {data_dir, "data/barrel_docdb"},
        {default_store, barrel_store_rocksdb},
        {tracing, [
            {enabled, true},
            {exporter, none}  %% set to console or otlp in a deployment
        ]}
    ]},

    {kernel, [
        {logger_level, info},
        {logger, [
            {handler, default, logger_std_h, #{
                level => info,
                formatter => {logger_formatter, #{
                    single_line => true,
                    template => [time, " [", level, "] ", pid, " ", msg, "\n"]
                }}
            }}
        ]}
    ]}
].
