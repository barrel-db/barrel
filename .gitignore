# rebar3 / Erlang
_build/
.rebar3/
*.beam
*.plt
*.coverdata
erl_crash.dump
rebar3.crashdump
*.crashdump

# Claude Code harness session files
.claude/

# Compiled NIFs
priv/*.so
priv/*.dylib
**/priv/*.so
**/priv/*.dylib

# Stray umbrella-root priv (e.g. default vectordb store path during dev/smoke)
/priv/

# CMake build output
**/_build/cmake/

# Runtime data
**/data/
**/log/

# Python (embed / rerank venvs)
**/.venv/
**/venv/
**/__pycache__/
*.pyc

# barrel-lite (TS client)
node_modules/
clients/barrel-lite/dist/
clients/barrel-lite/test-results/
clients/barrel-lite/playwright-report/
clients/barrel-lite/blob-report/

# Editors / OS
.DS_Store
*~

# leex/yecc output (generated from src/*.xrl and src/*.yrl)
apps/*/src/barrel_bql_lexer.erl
apps/*/src/barrel_bql_parser.erl

# per-app lock files (umbrella root rebar.lock is authoritative)
apps/*/rebar.lock

# ex_doc output (regenerate with `rebar3 ex_doc`)
apps/*/doc/

# rebar3 sibling-app overrides (created by CI and the docs script)
apps/*/_checkouts/
results/
