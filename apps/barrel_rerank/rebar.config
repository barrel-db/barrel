%% nowarn_deprecated_catch: two modules use the prefix `catch' operator,
%% deprecated on OTP 29. Suppress just that deprecation; keep the rest strict.
{erl_opts, [debug_info, warnings_as_errors, nowarn_deprecated_catch]}.

{deps, []}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

%% Library API: exports are consumed by external callers, so do not enable
%% exports_not_used (it would flag every public function).
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{profiles, [
    {test, [{deps, [{meck, "1.2.0"}]}]}
]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/barrel-db/barrel">>},
    {source_url_pattern,
        <<"https://github.com/barrel-db/barrel/blob/main/apps/barrel_rerank/%{path}#L%{line}">>},
    {homepage_url, <<"https://barrel-db.eu">>},
    {logo, "assets/logo.png"},
    {extras, [
        <<"README.md">>,
        <<"CHANGELOG.md">>,
        <<"LICENSE">>
    ]},
    {main, <<"readme">>},
    {api_reference, true},
    {groups_for_extras, [
        {<<"About">>, [<<"CHANGELOG.md">>, <<"LICENSE">>]}
    ]},
    {before_closing_head_tag, #{html => "<style>
      :root {
        --main: #006B77; --mainDark: #00565F; --mainDarkest: #003D44;
        --mainLight: #75B6B2; --mainLightest: #E6F2F3;
        --link-color: #C65E59; --link-visited-color: #C65E59;
        --sidebarAccentMain: #C65E59; --searchAccentMain: #C65E59;
      }
      body.dark {
        --main: #75B6B2; --mainDark: #006B77; --mainDarkest: #003D44;
        --mainLight: #9BCECB; --mainLightest: #123033;
        --link-color: #E0837E; --link-visited-color: #E0837E;
        --sidebarAccentMain: #E0837E; --searchAccentMain: #E0837E;
      }
    </style>"}}
]}.
