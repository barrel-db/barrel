%% nowarn_deprecated_catch: two modules use the prefix `catch' operator,
%% deprecated on OTP 29. Suppress just that deprecation; keep the rest strict.
{erl_opts, [debug_info, warnings_as_errors, nowarn_deprecated_catch]}.

{deps, []}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

%% Library API: exports are consumed by external callers, so do not enable
%% exports_not_used (it would flag every public function).
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{profiles, [
    {test, [{deps, [{meck, "1.2.0"}]}]}
]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"CHANGELOG.md", #{title => "Changelog"}},
        {"LICENSE", #{title => "License"}}
    ]},
    {main, "README.md"},
    {homepage_url, "https://github.com/barrel-db/barrel_rerank"},
    {source_url, "https://github.com/barrel-db/barrel_rerank"}
]}.
