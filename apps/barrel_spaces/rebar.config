{erl_opts, [debug_info, warnings_as_errors]}.

%% Sibling apps in the umbrella, and hard runtime deps (they are in this app's
%% `applications' list). They MUST be in the default profile: rebar3_hex builds
%% the package's requirements from the default-profile lock, so a `hex' profile
%% dep never reaches the tarball. In the umbrella these resolve as project apps;
%% for the Hex package they resolve from Hex.
{deps, [
    {barrel_crypto, "~> 1.0"},
    {barrel_docdb, "~> 1.0"},
    {barrel, "~> 1.0"}
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Library API: exports are consumed by external callers, so do not
%% enable exports_not_used (it would flag every public function).
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/barrel-db/barrel">>},
    {homepage_url, <<"https://barrel-db.eu">>},
    {logo, "assets/logo.png"},
    {extras, [
        <<"README.md">>,
        <<"CHANGELOG.md">>,
        <<"LICENSE">>
    ]},
    {main, <<"readme">>},
    {api_reference, true},
    {groups_for_extras, [
        {<<"About">>, [<<"CHANGELOG.md">>, <<"LICENSE">>]}
    ]},
    {before_closing_head_tag, #{html => "<style>
      :root {
        --main: #006B77; --mainDark: #00565F; --mainDarkest: #003D44;
        --mainLight: #75B6B2; --mainLightest: #E6F2F3;
        --link-color: #C65E59; --link-visited-color: #C65E59;
        --sidebarAccentMain: #C65E59; --searchAccentMain: #C65E59;
      }
      body.dark {
        --main: #75B6B2; --mainDark: #006B77; --mainDarkest: #003D44;
        --mainLight: #9BCECB; --mainLightest: #123033;
        --link-color: #E0837E; --link-visited-color: #E0837E;
        --sidebarAccentMain: #E0837E; --searchAccentMain: #E0837E;
      }
    </style>"}}
]}.
