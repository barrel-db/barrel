{erl_opts, [debug_info]}.

%% hackney pinned to 4.4.5 to match barrel_vectordb in the umbrella build.
{deps, [
    {hackney, "4.4.5"}
]}.

{shell, [
    {apps, [barrel_embed]}
]}.

{profiles, [
    {test, [
        {deps, [
            {meck, "1.2.0"}
        ]},
        {eunit_opts, [verbose]}
    ]}
]}.

{dialyzer, [
    {warnings, [unknown]},
    {plt_apps, all_deps}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{project_plugins, [rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"LICENSE", #{title => "License"}}
    ]},
    {main, "README.md"},
    {homepage_url, "https://docs.barrel-db.eu/embed/"},
    {source_url, "https://github.com/barrel-db/barrel_embed"}
]}.
