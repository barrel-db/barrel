{erl_opts, [debug_info]}.

{cover_enabled, true}.

%% hackney pinned to 4.4.5 to match barrel_vectordb in the umbrella build.
{deps, [
    {hackney, "4.4.5"}
]}.

{shell, [
    {apps, [barrel_embed]}
]}.

{profiles, [
    {test, [
        {deps, [
            {meck, "1.2.0"}
        ]},
        {eunit_opts, [verbose]}
    ]}
]}.

{dialyzer, [
    {warnings, [unknown]},
    {plt_apps, all_deps}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/barrel-db/barrel">>},
    {source_url_pattern,
        <<"https://github.com/barrel-db/barrel/blob/main/apps/barrel_embed/%{path}#L%{line}">>},
    {homepage_url, <<"https://barrel-db.eu">>},
    {logo, "assets/logo.png"},
    {extras, [
        <<"README.md">>,
        <<"docs/getting-started.md">>,
        <<"docs/choosing-provider.md">>,
        <<"docs/venv-setup.md">>,
        <<"docs/dev/adding-provider.md">>,
        <<"docs/providers/overview.md">>,
        <<"docs/providers/azure.md">>,
        <<"docs/providers/bedrock.md">>,
        <<"docs/providers/clip.md">>,
        <<"docs/providers/cohere.md">>,
        <<"docs/providers/colbert.md">>,
        <<"docs/providers/fastembed.md">>,
        <<"docs/providers/jina.md">>,
        <<"docs/providers/local.md">>,
        <<"docs/providers/mistral.md">>,
        <<"docs/providers/ollama.md">>,
        <<"docs/providers/openai.md">>,
        <<"docs/providers/splade.md">>,
        <<"docs/providers/vertex.md">>,
        <<"docs/providers/voyage.md">>,
        <<"docs/design.md">>,
        <<"CHANGELOG.md">>,
        <<"LICENSE">>
    ]},
    {main, <<"readme">>},
    {api_reference, true},
    {groups_for_extras, [
        {<<"Getting Started">>, [
            <<"docs/getting-started.md">>,
            <<"docs/choosing-provider.md">>
        ]},
        {<<"Guides">>, [
            <<"docs/venv-setup.md">>,
            <<"docs/dev/adding-provider.md">>
        ]},
        {<<"Providers">>, [
            <<"docs/providers/overview.md">>,
            <<"docs/providers/azure.md">>,
            <<"docs/providers/bedrock.md">>,
            <<"docs/providers/clip.md">>,
            <<"docs/providers/cohere.md">>,
            <<"docs/providers/colbert.md">>,
            <<"docs/providers/fastembed.md">>,
            <<"docs/providers/jina.md">>,
            <<"docs/providers/local.md">>,
            <<"docs/providers/mistral.md">>,
            <<"docs/providers/ollama.md">>,
            <<"docs/providers/openai.md">>,
            <<"docs/providers/splade.md">>,
            <<"docs/providers/vertex.md">>,
            <<"docs/providers/voyage.md">>
        ]},
        {<<"Architecture">>, [
            <<"docs/design.md">>
        ]},
        {<<"About">>, [
            <<"CHANGELOG.md">>,
            <<"LICENSE">>
        ]}
    ]},
    {skip_undefined_reference_warnings_on, [<<".*">>]},
    {before_closing_head_tag, #{html => "<style>
      :root {
        --main: #006B77; --mainDark: #00565F; --mainDarkest: #003D44;
        --mainLight: #75B6B2; --mainLightest: #E6F2F3;
        --link-color: #C65E59; --link-visited-color: #C65E59;
        --sidebarAccentMain: #C65E59; --searchAccentMain: #C65E59;
      }
      body.dark {
        --main: #75B6B2; --mainDark: #006B77; --mainDarkest: #003D44;
        --mainLight: #9BCECB; --mainLightest: #123033;
        --link-color: #E0837E; --link-visited-color: #E0837E;
        --sidebarAccentMain: #E0837E; --searchAccentMain: #E0837E;
      }
    </style>"}}
]}.
