%% barrel_server is built as part of the umbrella via the top-level `server`
%% profile (it adds apps/barrel_server to project_app_dirs). The `barrel`
%% facade resolves as a sibling umbrella app; livery is pulled from Hex.
{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{cover_enabled, true}.

{deps, [
    {livery, "0.5.1"},
    %% exact pin: the MCP engine livery_mcp bridges to (inside
    %% livery's ~> 2.2.4 constraint; rebar fails loudly on conflict)
    {barrel_mcp, "2.2.4"}
]}.

{shell, [
    {apps, [barrel_server]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"LICENSE", #{title => "License"}}
    ]},
    {main, "README.md"},
    {source_url, "https://github.com/barrel-db/barrel"}
]}.

%% Standalone Hex publish: the sibling apps resolve locally in the umbrella,
%% but on Hex they must be versioned packages. livery and barrel_mcp are
%% already Hex deps in the default `deps`.
{profiles, [
    {hex, [
        {deps, [
            {barrel, "~> 0.2"},
            {barrel_spaces, "~> 0.2"}
        ]}
    ]}
]}.
