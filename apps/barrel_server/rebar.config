%% barrel_server is built as part of the umbrella via the top-level `server`
%% profile (it adds apps/barrel_server to project_app_dirs). The `barrel`
%% facade resolves as a sibling umbrella app; livery is pulled here.
{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {livery, {git, "https://github.com/benoitc/livery.git", {tag, "v0.3.2"}}}
]}.

{shell, [
    {apps, [barrel_server]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.
