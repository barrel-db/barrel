{erl_opts, [
    debug_info,
    warnings_as_errors,
    %% A few modules use the prefix `catch' operator, deprecated on OTP 29.
    %% Suppress just that deprecation so the rest stays strict.
    nowarn_deprecated_catch
]}.

%% barrel_embed is a local umbrella app (apps/barrel_embed), discovered
%% automatically; it is no longer pulled from Hex here.
{deps, [
    %% Encryption at rest (sibling app; barrel_vectordb_crypto calls it).
    {barrel_crypto, "1.0.0"},
    {rocksdb, "3.1.1"},
    {hackney, "4.4.5"},
    {iommap, "1.1.3"},
    {gen_batch_server, "0.10.0"}  %% write batching for per-store servers
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% CMake-based NIF build
{pre_hooks, [
    {"(linux|darwin)", compile, "./do_cmake.sh"},
    {"(linux|darwin)", clean, "rm -rf _build/cmake priv/barrel_vectordb_nif.so"}
]}.

{post_hooks, [
    {"(linux|darwin)", compile, "cmake --build _build/cmake --parallel"}
]}.

%% EUnit configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Shell configuration for development
{shell, [
    {apps, [barrel_vectordb]}
]}.

%% Xref configuration
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.
{xref_ignores, [
    %% Optional embedding support
    {barrel_embed, '_', '_'},
    %% Optional reranking support
    {barrel_rerank, '_', '_'},
    %% Optional FAISS backend
    {barrel_vectordb_index_faiss, '_', '_'},
    {barrel_faiss, '_', '_'},
    %% Benchmark modules
    {barrel_vectordb_bench, '_', '_'},
    {barrel_vectordb_hybrid_bench, '_', '_'},
    {bench_ranking, '_', '_'},
    {bench_normalized, '_', '_'},
    {bench_divergence, '_', '_'}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_extra_apps, [barrel_embed, rocksdb, hackney, iommap, gen_batch_server]},
    %% Exclude FAISS backend module - barrel_faiss is an optional dependency
    %% Exclude benchmark modules - compiled without debug_info in bench profile
    {exclude_mods, [barrel_vectordb_index_faiss,
                    barrel_vectordb_bench, barrel_vectordb_hybrid_bench,
                    bench_ranking, bench_normalized, bench_divergence]}
]}.

%% HexDocs configuration
{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/barrel-db/barrel">>},
    {source_url_pattern,
        <<"https://github.com/barrel-db/barrel/blob/main/apps/barrel_vectordb/%{path}#L%{line}">>},
    {homepage_url, <<"https://barrel-db.eu">>},
    {logo, "assets/logo.png"},
    {extras, [
        <<"README.md">>,
        <<"docs/getting-started.md">>,
        <<"docs/embeddings.md">>,
        <<"docs/features.md">>,
        <<"docs/bm25-disk.md">>,
        <<"docs/guides/turboquant.md">>,
        {<<"docs/internals/turboquant-internals.md">>, #{title => <<"TurboQuant Internals">>}},
        <<"docs/development/contributing.md">>,
        <<"CHANGELOG.md">>,
        <<"LICENSE">>
    ]},
    {main, <<"readme">>},
    {api_reference, true},
    {groups_for_extras, [
        {<<"Getting Started">>, [
            <<"docs/getting-started.md">>
        ]},
        {<<"Guides">>, [
            <<"docs/embeddings.md">>,
            <<"docs/features.md">>,
            <<"docs/bm25-disk.md">>,
            <<"docs/guides/turboquant.md">>
        ]},
        {<<"Architecture">>, [
            <<"docs/internals/turboquant-internals.md">>
        ]},
        {<<"About">>, [
            <<"docs/development/contributing.md">>,
            <<"CHANGELOG.md">>,
            <<"LICENSE">>
        ]}
    ]},
    {skip_undefined_reference_warnings_on, [<<".*">>]},
    {before_closing_head_tag, #{html => "<style>
      :root {
        --main: #006B77; --mainDark: #00565F; --mainDarkest: #003D44;
        --mainLight: #75B6B2; --mainLightest: #E6F2F3;
        --link-color: #C65E59; --link-visited-color: #C65E59;
        --sidebarAccentMain: #C65E59; --searchAccentMain: #C65E59;
      }
      body.dark {
        --main: #75B6B2; --mainDark: #006B77; --mainDarkest: #003D44;
        --mainLight: #9BCECB; --mainLightest: #123033;
        --link-color: #E0837E; --link-visited-color: #E0837E;
        --sidebarAccentMain: #E0837E; --searchAccentMain: #E0837E;
      }
    </style>"}}
]}.

%% Release configuration
{relx, [
    {release, {barrel_vectordb, "2.1.1"}, [
        barrel_vectordb,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "1.2.0"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    {bench, [
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]},
        {eunit_opts, [verbose, {report, {eunit_surefire, [{dir, "_build/bench/logs"}]}}]}
    ]},
    %% Publishing profile. In the umbrella, barrel_embed is discovered as a local
    %% app; when this package is published to Hex it must declare the sibling as a
    %% Hex dependency. Build/publish with `rebar3 as hex ...`.
    {hex, [
        {deps, [
            {barrel_embed, "~> 2.3"}
        ]}
    ]},
    %% Embedding support: barrel_embed is a local umbrella app, built by default.
    %% Kept as a no-op so `rebar3 as embed compile` still works.
    {embed, []},
    %% Reranking support: barrel_rerank is a local umbrella app, built by default.
    {rerank, []},
    %% FAISS backend: the barrel_faiss app is opted in by the top-level `faiss`
    %% profile (it adds apps/barrel_faiss to project_app_dirs).
    %% Enable with: rebar3 as faiss compile
    {faiss, []},
    %% Combined test profile with embed support (embed is already built).
    {test_embed, [
        {deps, [
            {meck, "1.2.0"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Combined test profile with FAISS support.
    %% Opt the FAISS app in at the top level, e.g. `rebar3 as faiss,test_faiss ct`.
    {test_faiss, [
        {deps, [
            {meck, "1.2.0"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Full test profile. All optional deps are local umbrella apps; opt FAISS in
    %% via the top-level `faiss` profile.
    {test_full, [
        {deps, [
            {meck, "1.2.0"}
        ]},
        {extra_src_dirs, ["test/integration"]}
    ]},
    %% Benchmarks with FAISS support (opt the app in via the top-level `faiss`
    %% profile).
    {bench_faiss, [
        {erl_opts, [
            debug_info,
            {d, 'BENCHMARK'}
        ]},
        {extra_src_dirs, ["bench"]}
    ]}
]}.
