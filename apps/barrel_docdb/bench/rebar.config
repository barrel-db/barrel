{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    %% Match the rocksdb version barrel_docdb itself uses, so benchmark
    %% numbers reflect the library's actual storage engine.
    {rocksdb, "3.0.0"},
    {barrel_docdb, {git, "https://github.com/barrel-db/barrel_docdb.git", {branch, "main"}}}
]}.

%% NOTE: barrel_docdb is linked via _checkouts/barrel_docdb for local development
%% The git dep is just for dependency resolution; _checkouts takes precedence

%% instrument (transitive via barrel_docdb) and its hackney dep still use the
%% prefix `catch' operator, deprecated on OTP 29. Scope the suppression to
%% those dependencies.
{overrides, [
    {add, instrument, [{erl_opts, [nowarn_deprecated_catch]}]},
    {add, hackney, [{erl_opts, [nowarn_deprecated_catch]}]}
]}.

{shell, [
    {apps, [barrel_bench]}
]}.
