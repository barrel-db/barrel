%% The benchmark builds against the umbrella, not as a standalone project. Use
%% ./run_bench.sh, which compiles these sources against the umbrella's output
%% (its real rocksdb and deps) and runs them. See test/e2e/BENCHMARKS.md for a
%% reference run.
%%
%% barrel_docdb used to be resolved here as a git dependency on its old per-app
%% repository. That repository is archived; the app now lives in the umbrella
%% at apps/barrel_docdb, so there is no external dependency to declare.

{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, []}.
